# ─── PROD — serveur Windows MHP (install natif via NSSM) ───────
# Copier en `.env` à la racine du projet, éditer DB_PASSWORD.

# PostgreSQL local (même serveur Windows)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=pilotage_mhp
DB_USER=mhp_user
DB_PASSWORD=REMPLACER_PAR_LE_VRAI_MOT_DE_PASSE

LOG_LEVEL=INFO
POOL_MIN_SIZE=1
POOL_MAX_SIZE=10
DEFAULT_PAGE_SIZE=500
MAX_PAGE_SIZE=5000

# Auth API désactivée (laisser vide).
API_USERNAME=
API_PASSWORD=

# ─── OAuth Google (optionnel — pour mhp.gmail / mhp.drive / mhp.sheets) ───
# Voir DEPLOY.md §"Configuration OAuth Google" pour la procédure GCP.
# Laisser vide si tu n'utilises pas les intégrations Google.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Doit correspondre EXACTEMENT à l'URI ajoutée dans GCP > Identifiants OAuth
GOOGLE_OAUTH_REDIRECT_URI=http://192.168.1.7:8081/api/integrations/google/callback

# ─── SMTP (optionnel — pour mhp.mail.send sans Gmail OAuth) ───
# MHP_SMTP_HOST=smtp.gmail.com
# MHP_SMTP_PORT=587
# MHP_SMTP_USER=robot@mhp.fr
# MHP_SMTP_PASSWORD=app_password
# MHP_SMTP_FROM=robot@mhp.fr
