# ─── PROD — serveur Windows MHP (install natif via NSSM) ───────
# Copier en `.env` à la racine du projet, éditer DB_PASSWORD.

# PostgreSQL local (même serveur Windows)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=pilotage_mhp
DB_USER=mhp_user
DB_PASSWORD=REMPLACER_PAR_LE_VRAI_MOT_DE_PASSE

LOG_LEVEL=INFO
POOL_MIN_SIZE=1
POOL_MAX_SIZE=10
DEFAULT_PAGE_SIZE=500
MAX_PAGE_SIZE=5000

# Auth API désactivée (laisser vide).
API_USERNAME=
API_PASSWORD=
