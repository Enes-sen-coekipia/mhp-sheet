# ─── PROD — serveur Windows MHP ────────────────────────────────
# Copier en `.env` sur le serveur, éditer DB_HOST + DB_PASSWORD.
# Le PostgreSQL 18 client est déjà installé sur l'hôte Windows.

# Si PostgreSQL tourne sur le même serveur Windows que Docker :
DB_HOST=host.docker.internal
# Sinon (PG sur une autre machine du LAN) : mettre l'IP, ex 192.168.1.7
# DB_HOST=192.168.1.7

DB_PORT=5432
DB_NAME=pilotage_mhp
DB_USER=mhp_user
DB_PASSWORD=REMPLACER_PAR_LE_VRAI_MOT_DE_PASSE

LOG_LEVEL=INFO
POOL_MIN_SIZE=1
POOL_MAX_SIZE=10
DEFAULT_PAGE_SIZE=500
MAX_PAGE_SIZE=5000

# Auth API désactivée (laisser vide).
API_USERNAME=
API_PASSWORD=
