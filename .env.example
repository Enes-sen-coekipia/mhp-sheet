# ─── PostgreSQL ────────────────────────────────────────────────
# En local Docker, laisser DB_HOST=postgres (nom du service compose)
# En prod (serveur Windows client), mettre l'IP du serveur
POSTGRES_DB=pilotage_mhp
POSTGRES_USER=mhp_user
POSTGRES_PASSWORD=changeme_postgres

DB_HOST=postgres
DB_PORT=5432
DB_NAME=pilotage_mhp
DB_USER=mhp_user
DB_PASSWORD=changeme_postgres

# ─── Authentification API (HTTP Basic) ─────────────────────────
# Identifiants utilisés par l'interface web pour appeler le backend
API_USERNAME=mhp
API_PASSWORD=changeme_api_at_least_8_chars

# ─── Divers ────────────────────────────────────────────────────
LOG_LEVEL=INFO
POOL_MIN_SIZE=1
POOL_MAX_SIZE=10
DEFAULT_PAGE_SIZE=500
MAX_PAGE_SIZE=5000

# CORS — vide = même origine uniquement (cas Nginx). Sinon liste JSON.
# CORS_ORIGINS=["https://datasheet.mhp.local"]
